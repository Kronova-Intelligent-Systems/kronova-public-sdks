{
  "name": "@kronova-intelligent-systems/kronova-sdk",
  "version": "0.1.2",
  "description": "AetherNet v2.1 Agent SDK with Post-Quantum E2EE and AP2 Settlement",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "kronova",
    "aethernet",
    "ai-agents",
    "ap2",
    "post-quantum",
    "kyber",
    "dilithium"
  ],
  "author": "Kronova Engineering",
  "license": "MIT",
  "dependencies": {
    "@kronova-intelligent-systems/aethernet-pqc-sdk": "^0.1.2",
    "@supabase/supabase-js": "2.39.3",
    "dilithium-crystals-js": "1.1.3",
    "jose": "^6.2.2",
    "mlkem": "2.5.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ]
}
