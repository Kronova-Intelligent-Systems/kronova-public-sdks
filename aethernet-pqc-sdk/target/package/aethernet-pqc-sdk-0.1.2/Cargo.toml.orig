[package]
name = "aethernet-pqc-sdk"
version = "0.1.2"
edition = "2024"
description = "FIPS-204 ML-DSA Execution Edge for the AetherNet Protocol"
license = "MIT OR Apache-2.0"
repository = "https://github.com/kronova-intelligent-systems/kronova-public-sdks/aethernet-pqc-sdk"


include = [
    "src/**/*",
    "Cargo.toml",
    "README.md"
]

[lib]
crate-type = ["cdylib", "rlib"]

[dependencies]
wasm-bindgen = "0.2"
crystals-dilithium = "2.0.0" 
getrandom = { version = "0.2", features = ["js"] }
base64 = "0.21" # 

[package.metadata.wasm-pack.profile.release]
wasm-opt = false
